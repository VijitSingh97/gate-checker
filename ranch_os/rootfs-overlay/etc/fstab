# /etc/fstab — overlay-installed so systemd mounts /boot at runtime.
#
# Without the /boot entry, the FAT boot partition (mmcblk0p1) is read by
# the GPU bootloader at startup but is invisible to userspace once Linux
# is up. The provisioner reads /boot/provision_creds.env and the gate
# reads /boot/gate_config.env, both of which are written by the factory
# flash scripts to that FAT partition — so we must mount it.
#
# The rest of the entries are Buildroot's stock skeleton fstab.

# <file system>  <mount pt>   <type>   <options>                  <dump>  <pass>
/dev/root        /            ext4     rw,noauto                  0       1
/dev/mmcblk0p1   /boot        vfat     defaults,noatime           0       2
proc             /proc        proc     defaults                   0       0
devpts           /dev/pts     devpts   defaults,gid=5,mode=620,ptmxmode=0666  0  0
tmpfs            /dev/shm     tmpfs    mode=0777                  0       0
tmpfs            /tmp         tmpfs    mode=1777                  0       0
tmpfs            /run         tmpfs    mode=0755,nosuid,nodev     0       0
sysfs            /sys         sysfs    defaults                   0       0
