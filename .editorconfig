# https://editorconfig.org — keep whitespace consistent across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown allows trailing whitespace to mean "hard line break"; don't
# strip it. Indent inside lists is 2 spaces by convention.
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML and TOML idiomatically use 2-space indent.
[*.{yml,yaml,toml}]
indent_size = 2

# Makefiles require literal tabs.
[{Makefile,*.mk}]
indent_style = tab
