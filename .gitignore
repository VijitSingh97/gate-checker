# ==============================================================================
# Ranch OS Build System
# ==============================================================================
releases/
*.img
*.iso
*.tar.gz

# Buildroot download / compiler caches used by the Docker build.
dl-cache/
ccache-dir/

# Buildroot scratch directories (created if Buildroot is run natively).
buildroot/output/
output/
output_base/
output_gate/
.config.old

# ==============================================================================
# Manufacturing secrets
# ==============================================================================
# The factory provisioners write Fernet keys and per-device AP / portal
# passwords here. Never commit this file.
manufacturing_inventory.csv
provision_creds.env
temp_config.env
# Sticker output captured from a real flash run — contains live portal
# passwords; never commit. If you save these for your records, keep them
# in a password manager, not the repo.
images_notes.txt

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.env
*.env
.venv/
venv/
ENV/
# Coverage / pytest artifacts — not produced by today's stdlib-unittest
# suite, but cheap to guard against if anyone later adds coverage or
# switches frameworks.
.coverage
.coverage.*
htmlcov/
coverage.xml
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==============================================================================
# IDE / OS
# ==============================================================================
.DS_Store
Thumbs.db
.vscode/
.cursor/
.idea/
.claude/
*.log
# Local-only developer log (used by Claude Code / other AI tools to
# keep session-by-session context). Not part of the public repo.
CLAUDE.md
# Editor swap / backup files. Vim's *.swp lives next to the file being
# edited; Emacs leaves *~ all over. Neither should ever land in git.
*.swp
*.swo
*~
*.bak
